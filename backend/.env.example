# .env.example
# ─────────────────────────────────────────────
# Copy this file to .env and fill in the values
#   Mac/Linux:  cp .env.example .env
#   Windows:    copy .env.example .env
# ─────────────────────────────────────────────

# MongoDB connection string
# Local:   mongodb://localhost:27017/smart_farming
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/smart_farming
MONGO_URI=mongodb://localhost:27017/smart_farming

# Secret key for JWT signing — change this to any long random string
JWT_SECRET=change_me_to_something_random_like_abc123xyz456

# JWT token expiry in hours
JWT_EXPIRE_HOURS=72

# Get a free API key from https://openweathermap.org/api
OPENWEATHER_API_KEY=paste_your_key_here

# Optional — Twilio SMS (for future offline alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Environment (development or production)
ENVIRONMENT=development
